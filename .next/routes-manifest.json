{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/blog/[slug]",
      "regex": "^/blog/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPslug": "nxtPslug"
      },
      "namedRegex": "^/blog/(?<nxtPslug>[^/]+?)(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/blog",
      "regex": "^/blog(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/blog(?:/)?$"
    },
    {
      "page": "/contacto",
      "regex": "^/contacto(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/contacto(?:/)?$"
    },
    {
      "page": "/icon.png",
      "regex": "^/icon\\.png(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/icon\\.png(?:/)?$"
    },
    {
      "page": "/nosotros",
      "regex": "^/nosotros(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/nosotros(?:/)?$"
    },
    {
      "page": "/proyectos",
      "regex": "^/proyectos(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/proyectos(?:/)?$"
    },
    {
      "page": "/proyectos/gestion-empresarial",
      "regex": "^/proyectos/gestion\\-empresarial(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/proyectos/gestion\\-empresarial(?:/)?$"
    },
    {
      "page": "/proyectos/impulsaq",
      "regex": "^/proyectos/impulsaq(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/proyectos/impulsaq(?:/)?$"
    },
    {
      "page": "/servicios",
      "regex": "^/servicios(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/servicios(?:/)?$"
    },
    {
      "page": "/servicios/abastecimiento",
      "regex": "^/servicios/abastecimiento(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/servicios/abastecimiento(?:/)?$"
    },
    {
      "page": "/servicios/consultoria",
      "regex": "^/servicios/consultoria(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/servicios/consultoria(?:/)?$"
    },
    {
      "page": "/servicios/infraestructura",
      "regex": "^/servicios/infraestructura(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/servicios/infraestructura(?:/)?$"
    },
    {
      "page": "/servicios/mercado-publico",
      "regex": "^/servicios/mercado\\-publico(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/servicios/mercado\\-publico(?:/)?$"
    },
    {
      "page": "/servicios/soluciones-tecnologicas",
      "regex": "^/servicios/soluciones\\-tecnologicas(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/servicios/soluciones\\-tecnologicas(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "rsc",
    "varyHeader": "rsc, next-router-state-tree, next-router-prefetch, next-router-segment-prefetch",
    "prefetchHeader": "next-router-prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSuffix": ".prefetch.rsc",
    "prefetchSegmentHeader": "next-router-segment-prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments"
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  }
}